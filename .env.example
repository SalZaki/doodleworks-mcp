# Doodleworks MCP — environment template
#
# Copy to `.env` for local reference, OR (the usual path) put these in your MCP
# host's server `env` block. The server reads them from process.env directly and
# does NOT auto-load a .env file. Never commit a real key — `.env` is gitignored.

# --- Image provider key (set ONE) -------------------------------------------
# OpenAI GPT Image (default provider).
OPENAI_API_KEY=sk-...
# Gemini 3 Pro Image ("Nano Banana Pro"). GOOGLE_API_KEY is accepted as a fallback.
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# --- Optional tuning (all have safe defaults) -------------------------------
# Default style-reference id/path (see "Style-reference library" in the README).
# DOODLEWORKS_STYLE_REF=your-reference.png
# Default image quality: low | medium | high | auto  (default: low)
# DOODLEWORKS_QUALITY=low
# Illustrations rendered in parallel (default: 3; raise to 6+ on higher API tiers)
# DOODLEWORKS_CONCURRENCY=3
# Per-image request timeout in ms (default: 120000); a render that stalls past it fails fast
# DOODLEWORKS_REQUEST_TIMEOUT_MS=120000
# Port for the local Streamable HTTP server used in development (default: 3001)
# PORT=3001
